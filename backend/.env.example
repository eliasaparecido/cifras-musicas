PORT=3002
DATABASE_URL="file:./dev.db"
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# Troque este valor em produção por um segredo forte e único.
AUTH_RESET_SECRET="trocar-em-producao-reset-secret"

# SMTP opcional: se não configurar, o link de reset vai para o log do backend.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="no-reply@cifras-musicais.local"
